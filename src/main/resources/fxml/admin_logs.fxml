<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminLogController">
	<top>
		<VBox spacing="12.0" styleClass="toolbar-panel">
			<VBox spacing="4.0">
				<Label text="管理员操作日志" styleClass="page-title" />
				<Label fx:id="currentUserLabel" styleClass="subtitle-text" />
			</VBox>
			<HBox spacing="10.0">
				<Button text="刷新日志" onAction="#handleRefresh"
					styleClass="primary-button" />
				<Button text="返回后台" onAction="#handleBack"
					styleClass="secondary-button" />
			</HBox>
		</VBox>
	</top>
	<center>
		<VBox spacing="10.0">
			<padding>
				<Insets top="16.0" right="0.0" bottom="0.0" left="0.0" />
			</padding>
			<Label text="最近操作" styleClass="section-label" />
			<TableView fx:id="logTable" VBox.vgrow="ALWAYS">
				<columns>
					<TableColumn fx:id="adminColumn" text="管理员"
						prefWidth="110.0" />
					<TableColumn fx:id="actionColumn" text="操作类型"
						prefWidth="110.0" />
					<TableColumn fx:id="targetTypeColumn" text="对象类型"
						prefWidth="90.0" />
					<TableColumn fx:id="targetIdColumn" text="对象ID"
						prefWidth="70.0" />
					<TableColumn fx:id="detailColumn" text="操作内容"
						prefWidth="250.0" />
					<TableColumn fx:id="createdAtColumn" text="操作时间"
						prefWidth="140.0" />
				</columns>
			</TableView>
		</VBox>
	</center>
</BorderPane>
