<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.UserHomeController">
	<top>
		<VBox spacing="14.0" styleClass="toolbar-panel">
			<VBox spacing="4.0">
				<Label text="商品市场" styleClass="page-title" />
				<Label fx:id="currentUserLabel" styleClass="subtitle-text" />
			</VBox>
			<HBox alignment="CENTER_LEFT" spacing="12.0">
				<VBox spacing="6.0">
					<Label text="关键词" styleClass="field-label" />
					<TextField fx:id="keywordField" prefWidth="280.0"
						promptText="名称、分类、描述、卖家" />
				</VBox>
				<VBox spacing="6.0">
					<Label text="分类" styleClass="field-label" />
					<ChoiceBox fx:id="categoryBox" prefWidth="130.0" />
				</VBox>
				<VBox spacing="6.0">
					<Label text="排序" styleClass="field-label" />
					<ChoiceBox fx:id="sortBox" prefWidth="150.0" />
				</VBox>
				<Button text="搜索" onAction="#handleSearch"
					styleClass="primary-button" />
				<Button text="重置" onAction="#handleReset"
					styleClass="secondary-button" />
			</HBox>
			<HBox alignment="CENTER_LEFT" spacing="10.0">
				<Button text="发布商品" onAction="#handlePublish"
					styleClass="primary-button" />
				<Button text="查看所选详情" onAction="#handleDetail"
					styleClass="secondary-button" />
				<Button text="我的发布" onAction="#handleMyPublished"
					styleClass="secondary-button" />
				<Button text="个人中心" onAction="#handleUserCenter"
					styleClass="secondary-button" />
				<Button text="购物车" onAction="#handleCart"
					styleClass="secondary-button" />
				<Button text="退出登录" onAction="#handleLogout"
					styleClass="secondary-button" />
			</HBox>
			<Label fx:id="messageLabel" wrapText="true"
				styleClass="status-text" />
		</VBox>
	</top>
	<center>
		<VBox spacing="10.0">
			<padding>
				<Insets top="16.0" right="0.0" bottom="0.0" left="0.0" />
			</padding>
			<Label text="可购买商品" styleClass="section-label" />
			<TableView fx:id="goodsTable" VBox.vgrow="ALWAYS">
				<columns>
					<TableColumn fx:id="titleColumn" text="商品名称"
						prefWidth="190.0" />
					<TableColumn fx:id="categoryColumn" text="分类"
						prefWidth="100.0" />
					<TableColumn fx:id="priceColumn" text="现价"
						prefWidth="90.0" />
					<TableColumn fx:id="conditionColumn" text="成色"
						prefWidth="80.0" />
					<TableColumn fx:id="imageColumn" text="主图"
						prefWidth="150.0" />
					<TableColumn fx:id="sellerColumn" text="卖家"
						prefWidth="120.0" />
					<TableColumn fx:id="createdAtColumn" text="发布时间"
						prefWidth="160.0" />
					<TableColumn fx:id="statusColumn" text="状态"
						prefWidth="100.0" />
				</columns>
			</TableView>
		</VBox>
	</center>
</BorderPane>
