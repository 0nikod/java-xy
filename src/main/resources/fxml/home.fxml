<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campus.secondhand.controller.UserHomeController">
    <top>
        <VBox spacing="10.0" styleClass="hero-panel">
            <padding>
                <Insets top="18.0" right="22.0" bottom="18.0" left="22.0"/>
            </padding>
            <HBox spacing="12.0">
                <VBox spacing="4.0">
                    <Label text="商品首页" styleClass="section-label"/>
                    <Label fx:id="currentUserLabel" styleClass="subtitle-text"/>
                </VBox>
                <Label text="关键词"/>
                <TextField fx:id="keywordField" promptText="搜索名称、分类、描述、卖家" prefWidth="300.0"/>
                <Label text="分类"/>
                <ChoiceBox fx:id="categoryBox" prefWidth="120.0"/>
                <Label text="排序"/>
                <ChoiceBox fx:id="sortBox" prefWidth="140.0"/>
                <Button text="搜索" onAction="#handleSearch" styleClass="primary-button"/>
                <Button text="重置" onAction="#handleReset" styleClass="secondary-button"/>
                <Button text="发布商品" onAction="#handlePublish" styleClass="primary-button"/>
                <Button text="我的发布" onAction="#handleMyPublished" styleClass="secondary-button"/>
                <Button text="查看详情" onAction="#handleDetail" styleClass="secondary-button"/>
                <Button text="退出登录" onAction="#handleLogout" styleClass="secondary-button"/>
            </HBox>
            <Label fx:id="messageLabel" wrapText="true" styleClass="subtitle-text"/>
        </VBox>
    </top>
    <center>
        <TableView fx:id="goodsTable">
            <columns>
                <TableColumn fx:id="titleColumn" text="商品名称" prefWidth="180.0"/>
                <TableColumn fx:id="categoryColumn" text="分类" prefWidth="100.0"/>
                <TableColumn fx:id="priceColumn" text="现价" prefWidth="90.0"/>
                <TableColumn fx:id="conditionColumn" text="成色" prefWidth="90.0"/>
                <TableColumn fx:id="sellerColumn" text="卖家" prefWidth="120.0"/>
                <TableColumn fx:id="createdAtColumn" text="发布时间" prefWidth="160.0"/>
                <TableColumn fx:id="statusColumn" text="状态" prefWidth="100.0"/>
            </columns>
        </TableView>
    </center>
</BorderPane>
