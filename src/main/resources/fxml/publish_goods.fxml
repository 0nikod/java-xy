<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.ColumnConstraints?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.PublishGoodsController">

	<top>
		<VBox spacing="16.0">
			<padding>
				<Insets bottom="24.0" />
			</padding>
			<HBox alignment="CENTER_LEFT" spacing="20.0">
				<Button text="← 取消" onAction="#handleBack"
					styleClass="secondary-button" />
				<Label text="发布商品" styleClass="page-title" />
				<Region HBox.hgrow="ALWAYS" />
				<Label fx:id="currentUserLabel" styleClass="muted-text" />
			</HBox>
		</VBox>
	</top>

	<center>
		<HBox spacing="30.0">

			<!-- Left Column: Product Details Form -->
			<VBox spacing="20.0" styleClass="plain-panel"
				HBox.hgrow="ALWAYS" maxWidth="600.0">
				<Label text="商品详情" styleClass="section-label" />

				<GridPane hgap="16.0" vgap="16.0">
					<columnConstraints>
						<ColumnConstraints minWidth="120.0"
							prefWidth="140.0" />
						<ColumnConstraints hgrow="ALWAYS" />
					</columnConstraints>

					<Label text="标题 *" styleClass="field-label"
						GridPane.columnIndex="0" GridPane.rowIndex="0" />
					<TextField fx:id="titleField" promptText="您要卖什么商品？"
						GridPane.columnIndex="1" GridPane.rowIndex="0" />

					<Label text="类别 *" styleClass="field-label"
						GridPane.columnIndex="0" GridPane.rowIndex="1" />
					<ChoiceBox fx:id="categoryBox" prefWidth="200.0"
						GridPane.columnIndex="1" GridPane.rowIndex="1" />

					<Label text="原价" styleClass="field-label"
						GridPane.columnIndex="0" GridPane.rowIndex="2" />
					<TextField fx:id="originalPriceField" promptText="0.00"
						GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="200.0" />

					<Label text="售价 *" styleClass="field-label"
						GridPane.columnIndex="0" GridPane.rowIndex="3" />
					<TextField fx:id="currentPriceField" promptText="0.00"
						GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="200.0" />

					<Label text="成色 *" styleClass="field-label"
						GridPane.columnIndex="0" GridPane.rowIndex="4" />
					<TextField fx:id="conditionField"
						promptText="例如 9成新、全新、二手" GridPane.columnIndex="1"
						GridPane.rowIndex="4" maxWidth="200.0" />
				</GridPane>

				<VBox spacing="8.0">
					<Label text="描述 *" styleClass="field-label" />
					<TextArea fx:id="descriptionArea" prefRowCount="6"
						wrapText="true" promptText="描述商品的成色、瑕疵以及取货说明。" />
				</VBox>

				<HBox spacing="12.0" alignment="CENTER_LEFT">
					<Button fx:id="optimizeButton" text="✨ AI 优化描述"
						onAction="#handleOptimize" styleClass="secondary-button" />
					<Region HBox.hgrow="ALWAYS" />
					<Button text="提交审核" onAction="#handleSubmit"
						styleClass="primary-button" prefWidth="200.0" prefHeight="44.0" />
				</HBox>

				<TextArea fx:id="aiSuggestionArea" prefRowCount="3"
					wrapText="true" editable="false" promptText="AI 建议将显示在此处..."
					styleClass="text-area" />
			</VBox>

			<!-- Right Column: Images -->
			<VBox spacing="16.0" prefWidth="340.0" styleClass="plain-panel">
				<VBox spacing="4.0">
					<Label text="商品图片" styleClass="section-label" />
					<Label text="最多添加3张图片。第一张为封面。" styleClass="subtitle-text"
						wrapText="true" />
				</VBox>

				<Label fx:id="imageSummaryLabel" text="已选择 0 张图片。"
					styleClass="status-text" />

				<VBox alignment="CENTER"
					style="-fx-background-color: #F9FAFB; -fx-background-radius: 12; -fx-padding: 10;">
					<ImageView fx:id="imagePreviewView" fitWidth="280.0"
						fitHeight="200.0" preserveRatio="true" styleClass="image-preview" />
				</VBox>

				<ListView fx:id="imageListView" prefHeight="120.0" />

				<VBox spacing="10.0">
					<Button text="添加图片" onAction="#handleAddImages"
						styleClass="secondary-button" maxWidth="Infinity" />
					<HBox spacing="10" alignment="CENTER_LEFT">
						<Button text="设为封面" onAction="#handleSetPrimaryImage"
							styleClass="secondary-button" HBox.hgrow="ALWAYS"
							maxWidth="Infinity" />
						<Button text="移除" onAction="#handleRemoveImage"
							styleClass="danger-button" HBox.hgrow="ALWAYS"
							maxWidth="Infinity" />
					</HBox>
				</VBox>
			</VBox>

		</HBox>
	</center>
</BorderPane>
