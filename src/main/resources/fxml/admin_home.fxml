<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminHomeController">

	<top>
		<HBox alignment="CENTER_LEFT" spacing="20.0">
			<padding>
				<Insets bottom="32.0" />
			</padding>
			<VBox spacing="4.0">
				<Label text="管理员控制台" styleClass="page-title" />
				<Label fx:id="currentUserLabel" styleClass="muted-text" />
			</VBox>
			<Region HBox.hgrow="ALWAYS" />
			<Button text="退出登录" onAction="#handleLogout"
				styleClass="danger-button" />
		</HBox>
	</top>

	<center>
		<VBox spacing="24.0" maxWidth="800.0" alignment="TOP_CENTER">

			<HBox styleClass="hero-panel" alignment="CENTER_LEFT"
				spacing="20.0">
				<padding>
					<Insets top="24.0" right="30.0" bottom="24.0" left="30.0" />
				</padding>
				<VBox spacing="8.0" HBox.hgrow="ALWAYS">
					<Label text="系统概览" styleClass="section-label" />
					<Label fx:id="summaryLabel" wrapText="true"
						styleClass="subtitle-text" />
				</VBox>
				<Button text="✨ AI 管理分析"
					onAction="#handleAiManagementAnalysis" styleClass="primary-button"
					prefHeight="44.0" />
			</HBox>

			<HBox spacing="20.0">
				<!-- Moderation -->
				<VBox spacing="16.0" styleClass="plain-panel"
					HBox.hgrow="ALWAYS">
					<Label text="审核与管理" styleClass="section-label" />
					<VBox spacing="10.0">
						<Button text="审核待审商品" onAction="#handleReviewGoods"
							styleClass="primary-button" maxWidth="Infinity" />
						<Button text="用户管理" onAction="#handleManageUsers"
							styleClass="secondary-button" maxWidth="Infinity" />
					</VBox>
				</VBox>

				<!-- Operations -->
				<VBox spacing="16.0" styleClass="plain-panel"
					HBox.hgrow="ALWAYS">
					<Label text="平台运营" styleClass="section-label" />
					<VBox spacing="10.0">
						<Button text="平台统计" onAction="#handleViewStats"
							styleClass="secondary-button" maxWidth="Infinity" />
						<Button text="系统日志" onAction="#handleViewLogs"
							styleClass="secondary-button" maxWidth="Infinity" />
						<Button text="所有评价" onAction="#handleViewReviews"
							styleClass="secondary-button" maxWidth="Infinity" />
					</VBox>
				</VBox>
			</HBox>

		</VBox>
	</center>
</BorderPane>
