<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminReviewController">
	<top>
		<VBox spacing="12.0" styleClass="toolbar-panel">
			<VBox spacing="4.0">
				<Label text="全部评价" styleClass="page-title" />
				<Label fx:id="currentUserLabel" styleClass="subtitle-text" />
			</VBox>
			<HBox spacing="10.0">
				<Button text="刷新评价" onAction="#handleRefresh"
					styleClass="primary-button" />
				<Button text="返回后台" onAction="#handleBack"
					styleClass="secondary-button" />
			</HBox>
		</VBox>
	</top>
	<center>
		<VBox spacing="10.0">
			<padding>
				<Insets top="16.0" right="0.0" bottom="0.0" left="0.0" />
			</padding>
			<Label text="平台评价列表" styleClass="section-label" />
			<TableView fx:id="reviewTable" VBox.vgrow="ALWAYS">
				<columns>
					<TableColumn fx:id="goodsColumn" text="商品" prefWidth="140.0" />
					<TableColumn fx:id="reviewerColumn" text="评价用户" prefWidth="100.0" />
					<TableColumn fx:id="sellerColumn" text="卖家" prefWidth="100.0" />
					<TableColumn fx:id="ratingColumn" text="评分" prefWidth="70.0" />
					<TableColumn fx:id="contentColumn" text="内容" prefWidth="240.0" />
					<TableColumn fx:id="createdAtColumn" text="时间" prefWidth="140.0" />
				</columns>
			</TableView>
		</VBox>
	</center>
</BorderPane>
