<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminStatsController">

	<top>
		<VBox spacing="16.0">
			<padding>
				<Insets bottom="24.0" />
			</padding>
			<HBox alignment="CENTER_LEFT" spacing="20.0">
				<Button text="← 控制台" onAction="#handleBack"
					styleClass="secondary-button" />
				<VBox>
					<Label text="平台分析" styleClass="page-title" />
					<Label fx:id="currentUserLabel" styleClass="muted-text" />
				</VBox>
				<Region HBox.hgrow="ALWAYS" />
				<Button fx:id="refreshButton" text="刷新分析"
					onAction="#handleRefresh" styleClass="primary-button" />
			</HBox>

			<VBox spacing="12.0" styleClass="hero-panel"
				style="-fx-padding: 24;">
				<Label fx:id="statsCardLabel" wrapText="true"
					styleClass="section-label" />
				<HBox spacing="10.0">
					<Label text="✨ AI 洞察:"
						style="-fx-font-weight: bold; -fx-text-fill: #6366F1;" />
					<VBox spacing="4.0">
						<Label fx:id="aiSummaryLabel" wrapText="true"
							styleClass="subtitle-text" />
						<Label fx:id="chartInterpretationLabel" wrapText="true"
							styleClass="subtitle-text" />
					</VBox>
				</HBox>
			</VBox>
		</VBox>
	</top>

	<center>
		<ScrollPane fitToWidth="true"
			style="-fx-background-color: transparent;">
			<VBox spacing="20.0">
				<padding>
					<Insets right="10.0" />
				</padding>

				<HBox spacing="20.0">
					<VBox spacing="10.0" styleClass="plain-panel"
						HBox.hgrow="ALWAYS" alignment="CENTER">
						<Label text="商品类别分布" styleClass="section-label" />
						<PieChart fx:id="categoryPieChart" prefHeight="260.0" />
					</VBox>
					<VBox spacing="10.0" styleClass="plain-panel"
						HBox.hgrow="ALWAYS" alignment="CENTER">
						<Label text="商品状态分布" styleClass="section-label" />
						<BarChart fx:id="statusBarChart" prefHeight="260.0"
							legendVisible="false">
							<xAxis>
								<CategoryAxis label="状态" />
							</xAxis>
							<yAxis>
								<NumberAxis label="数量" />
							</yAxis>
						</BarChart>
					</VBox>
					<VBox spacing="10.0" styleClass="plain-panel"
						HBox.hgrow="ALWAYS" alignment="CENTER">
						<Label text="近期销售趋势" styleClass="section-label" />
						<LineChart fx:id="trendLineChart" prefHeight="260.0"
							legendVisible="false">
							<xAxis>
								<CategoryAxis label="日期" />
							</xAxis>
							<yAxis>
								<NumberAxis label="订单量" />
							</yAxis>
						</LineChart>
					</VBox>
				</HBox>

				<HBox spacing="20.0">
					<VBox spacing="10.0" styleClass="plain-panel"
						HBox.hgrow="ALWAYS" alignment="CENTER">
						<Label text="商品类别销量" styleClass="section-label" />
						<BarChart fx:id="categorySoldCountBarChart"
							prefHeight="260.0" legendVisible="false">
							<xAxis>
								<CategoryAxis label="类别" />
							</xAxis>
							<yAxis>
								<NumberAxis label="销量" />
							</yAxis>
						</BarChart>
					</VBox>
					<VBox spacing="10.0" styleClass="plain-panel"
						HBox.hgrow="ALWAYS" alignment="CENTER">
						<Label text="商品类别销售额" styleClass="section-label" />
						<BarChart fx:id="categoryRevenueBarChart"
							prefHeight="260.0" legendVisible="false">
							<xAxis>
								<CategoryAxis label="类别" />
							</xAxis>
							<yAxis>
								<NumberAxis label="销售额" />
							</yAxis>
						</BarChart>
					</VBox>
				</HBox>

				<VBox spacing="10.0" styleClass="plain-panel">
					<Label text="用户活动概览" styleClass="section-label" />
					<TableView fx:id="detailTable" prefHeight="260.0">
						<columns>
							<TableColumn fx:id="detailUserColumn" text="用户名"
								prefWidth="250.0" />
							<TableColumn fx:id="detailStatusColumn" text="账户状态"
								prefWidth="150.0" />
							<TableColumn fx:id="detailGoodsCountColumn"
								text="上架商品数" prefWidth="150.0" />
							<TableColumn fx:id="detailSoldCountColumn"
								text="售出商品数" prefWidth="150.0" />
						</columns>
					</TableView>
				</VBox>
			</VBox>
		</ScrollPane>
	</center>
</BorderPane>
