<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminGoodsReviewController">
	<top>
		<VBox spacing="8.0" styleClass="toolbar-panel">
			<Label text="商品审核" styleClass="page-title" />
			<Label fx:id="currentUserLabel" styleClass="subtitle-text" />
			<Label fx:id="detailLabel" wrapText="true"
				styleClass="status-text" />
		</VBox>
	</top>
	<center>
		<HBox spacing="16.0">
			<padding>
				<Insets top="16.0" right="0.0" bottom="0.0" left="0.0" />
			</padding>
			<VBox spacing="10.0" HBox.hgrow="ALWAYS">
				<Label text="待审核列表" styleClass="section-label" />
				<TableView fx:id="pendingTable" VBox.vgrow="ALWAYS">
					<columns>
						<TableColumn fx:id="titleColumn" text="商品名称"
							prefWidth="190.0" />
						<TableColumn fx:id="sellerColumn" text="卖家"
							prefWidth="120.0" />
						<TableColumn fx:id="categoryColumn" text="分类"
							prefWidth="100.0" />
						<TableColumn fx:id="priceColumn" text="现价"
							prefWidth="90.0" />
						<TableColumn fx:id="statusColumn" text="状态"
							prefWidth="100.0" />
					</columns>
				</TableView>
			</VBox>
			<VBox spacing="12.0" minWidth="280.0" styleClass="plain-panel">
				<Label text="审核操作" styleClass="section-label" />
				<Label text="选择左侧商品后，核对详情、图片和删除原因，再执行审核。"
					styleClass="subtitle-text" wrapText="true" />
				<Label text="删除原因" styleClass="field-label" />
				<TextArea fx:id="deleteReasonArea" prefRowCount="4"
					wrapText="true" promptText="删除违规商品时必填" />
				<Label text="商品图片" styleClass="field-label" />
				<ImageView fx:id="imagePreviewView" fitWidth="280.0"
					fitHeight="170.0" preserveRatio="true" styleClass="image-preview" />
				<ListView fx:id="imageListView" prefHeight="110.0" />
				<Button text="审核通过" onAction="#handleApprove"
					styleClass="primary-button" maxWidth="290.0" />
				<Button text="删除违规商品" onAction="#handleDelete"
					styleClass="danger-button" maxWidth="290.0" />
				<Button text="返回后台" onAction="#handleBack"
					styleClass="secondary-button" maxWidth="290.0" />
			</VBox>
		</HBox>
	</center>
</BorderPane>
