<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminGoodsReviewController">

	<top>
		<VBox spacing="16.0">
			<padding>
				<Insets bottom="24.0" />
			</padding>
			<HBox alignment="CENTER_LEFT" spacing="20.0">
				<Button text="← 控制台" onAction="#handleBack"
					styleClass="secondary-button" />
				<Label text="商品审核" styleClass="page-title" />
				<Region HBox.hgrow="ALWAYS" />
				<Label fx:id="currentUserLabel" styleClass="muted-text" />
			</HBox>
			<HBox styleClass="toolbar-panel">
				<Label fx:id="detailLabel" wrapText="true"
					styleClass="status-text" />
			</HBox>
		</VBox>
	</top>

	<center>
		<HBox spacing="24.0">
			<!-- Left Column: Pending Table -->
			<VBox spacing="16.0" HBox.hgrow="ALWAYS"
				styleClass="plain-panel">
				<Label text="待审商品" styleClass="section-label" />
				<TableView fx:id="pendingTable" VBox.vgrow="ALWAYS">
					<columns>
						<TableColumn fx:id="titleColumn" text="商品名称"
							prefWidth="240.0" />
						<TableColumn fx:id="sellerColumn" text="卖家"
							prefWidth="140.0" />
						<TableColumn fx:id="categoryColumn" text="类别"
							prefWidth="120.0" />
						<TableColumn fx:id="priceColumn" text="价格"
							prefWidth="100.0" />
						<TableColumn fx:id="statusColumn" text="状态"
							prefWidth="100.0" />
					</columns>
				</TableView>
			</VBox>

			<!-- Right Column: Moderation Actions -->
			<VBox spacing="20.0" prefWidth="380.0" styleClass="plain-panel">
				<VBox spacing="4.0">
					<Label text="审核与操作" styleClass="section-label" />
					<Label text="从列表中选择商品以查看其详细信息和图片。" styleClass="subtitle-text"
						wrapText="true" />
				</VBox>

				<VBox spacing="12.0" styleClass="hero-panel"
					style="-fx-padding: 16;">
					<ImageView fx:id="imagePreviewView" fitWidth="300.0"
						fitHeight="200.0" preserveRatio="true" styleClass="image-preview" />
					<ListView fx:id="imageListView" prefHeight="90.0"
						orientation="HORIZONTAL" styleClass="list-view" />
				</VBox>

				<VBox spacing="8.0" VBox.vgrow="ALWAYS">
					<Label text="拒绝原因（删除商品时必填）" styleClass="field-label" />
					<TextArea fx:id="deleteReasonArea" prefRowCount="4"
						wrapText="true" promptText="说明该商品为何违反平台规则..."
						styleClass="text-area" />
				</VBox>

				<HBox spacing="12.0">
					<Button text="违规删除" onAction="#handleDelete"
						styleClass="danger-button" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
					<Button text="审核通过" onAction="#handleApprove"
						styleClass="primary-button" HBox.hgrow="ALWAYS"
						maxWidth="Infinity" />
				</HBox>
			</VBox>
		</HBox>
	</center>
</BorderPane>
