<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.campus.secondhand.controller.AdminGoodsReviewController">
    <top>
        <VBox spacing="10.0" styleClass="hero-panel">
            <padding>
                <Insets top="18.0" right="22.0" bottom="18.0" left="22.0"/>
            </padding>
            <Label text="待审核商品" styleClass="section-label"/>
            <Label fx:id="currentUserLabel" styleClass="subtitle-text"/>
            <Label fx:id="detailLabel" wrapText="true" styleClass="subtitle-text"/>
        </VBox>
    </top>
    <center>
        <TableView fx:id="pendingTable">
            <columns>
                <TableColumn fx:id="titleColumn" text="商品名称" prefWidth="180.0"/>
                <TableColumn fx:id="sellerColumn" text="卖家" prefWidth="120.0"/>
                <TableColumn fx:id="categoryColumn" text="分类" prefWidth="100.0"/>
                <TableColumn fx:id="priceColumn" text="现价" prefWidth="90.0"/>
                <TableColumn fx:id="statusColumn" text="状态" prefWidth="100.0"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <VBox spacing="10.0" styleClass="hero-panel">
            <padding>
                <Insets top="16.0" right="22.0" bottom="18.0" left="22.0"/>
            </padding>
            <Label text="驳回原因" styleClass="section-label"/>
            <TextArea fx:id="rejectReasonArea" prefRowCount="3" wrapText="true" promptText="填写驳回原因"/>
            <Label text="商品图片" styleClass="section-label"/>
            <ListView fx:id="imageListView" prefHeight="90.0"/>
            <ImageView fx:id="imagePreviewView" fitWidth="220.0" fitHeight="150.0" preserveRatio="true"/>
            <HBox spacing="10.0">
                <Button text="审核通过" onAction="#handleApprove" styleClass="primary-button"/>
                <Button text="驳回商品" onAction="#handleReject" styleClass="secondary-button"/>
                <Button text="删除违规商品" onAction="#handleDelete" styleClass="secondary-button"/>
                <Button text="返回后台" onAction="#handleBack" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
