<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="auth-split"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.LoginController">
	<center>
		<HBox spacing="0" styleClass="hero-panel">
			<padding>
				<Insets top="0" right="0" bottom="0" left="0" />
			</padding>
			<VBox styleClass="auth-brand" spacing="20.0" alignment="CENTER_LEFT"
				HBox.hgrow="ALWAYS" minWidth="260">
				<Label text="校园二手交易平台" styleClass="brand-title" wrapText="true" />
				<Label text="教材 / 数码 / 服饰 / 生活用品"
					styleClass="brand-desc" wrapText="true" maxWidth="340" />
			</VBox>
			<VBox styleClass="auth-form-card" spacing="16.0"
				HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" minWidth="300">
				<Label text="用户登录" styleClass="title-text" />
				<VBox spacing="6.0">
					<Label text="用户名" styleClass="field-label" />
					<TextField fx:id="usernameField" promptText="请输入用户名" />
				</VBox>
				<VBox spacing="6.0">
					<Label text="密码" styleClass="field-label" />
					<PasswordField fx:id="passwordField" promptText="请输入密码" />
				</VBox>
				<Button text="进入系统" onAction="#handleLogin"
					styleClass="primary-button" maxWidth="1.7976931348623157E308" />
				<Button text="注册普通用户" onAction="#handleRegister"
					styleClass="secondary-button" maxWidth="1.7976931348623157E308" />
				<Label fx:id="hintLabel" wrapText="true"
					styleClass="status-text" />
			</VBox>
		</HBox>
	</center>
</BorderPane>
