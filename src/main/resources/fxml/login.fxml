<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="auth-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.LoginController">
	<center>
		<VBox alignment="CENTER_LEFT" maxWidth="520.0" spacing="18.0"
			styleClass="hero-panel">
			<padding>
				<Insets top="42.0" right="52.0" bottom="42.0" left="52.0" />
			</padding>
			<Label text="校园二手交易平台" styleClass="title-text" wrapText="true" />
			<Label text="登录后可以浏览商品、发布闲置、购买商品；管理员账号会进入后台审核与统计。"
				styleClass="subtitle-text" wrapText="true" />
			<VBox spacing="8.0">
				<Label text="用户名" styleClass="field-label" />
				<TextField fx:id="usernameField" promptText="请输入用户名"
					maxWidth="420.0" />
			</VBox>
			<VBox spacing="8.0">
				<Label text="密码" styleClass="field-label" />
				<PasswordField fx:id="passwordField"
					promptText="请输入密码" maxWidth="420.0" />
			</VBox>
			<Button text="进入系统" onAction="#handleLogin"
				styleClass="primary-button" maxWidth="420.0" />
			<Button text="注册普通用户" onAction="#handleRegister"
				styleClass="secondary-button" maxWidth="420.0" />
			<Label fx:id="hintLabel" wrapText="true" maxWidth="420.0"
				styleClass="status-text" />
		</VBox>
	</center>
</BorderPane>
