<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="auth-shell"
    xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.campus.secondhand.controller.LoginController"
    prefWidth="820.0" prefHeight="520.0">
    <center>
        <HBox alignment="CENTER" spacing="0.0">
            <!-- 左侧：标题区域，宽度从 300 增加到 360 -->
            <VBox alignment="CENTER" spacing="8.0"
                  prefWidth="360.0" styleClass="hero-panel">
                <padding>
                    <Insets top="48.0" right="48.0" bottom="48.0" left="48.0" />
                </padding>
                <Label text="欢迎回来" styleClass="title-text" />
                <Label text="登录校园二手交易平台" styleClass="subtitle-text" />
            </VBox>

            <!-- 右侧：表单区域，宽度从 380 增加到 440 -->
            <VBox alignment="CENTER" spacing="16.0"
                  prefWidth="440.0" styleClass="hero-panel">
                <padding>
                    <Insets top="48.0" right="48.0" bottom="48.0" left="48.0" />
                </padding>

                <GridPane hgap="12.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="50.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <Label text="用户名" styleClass="field-label"
                           GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="usernameField" promptText="请输入用户名"
                               prefHeight="42.0"
                               GridPane.rowIndex="0" GridPane.columnIndex="1" />
                    <Label text="密码" styleClass="field-label"
                           GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <PasswordField fx:id="passwordField" promptText="请输入密码"
                                   prefHeight="42.0"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1" />
                </GridPane>

                <!-- 按钮组跟随右侧区域自动伸展 -->
                <VBox spacing="12.0" maxWidth="Infinity">
                    <Button text="登录" onAction="#handleLogin"
                            styleClass="primary-button" prefHeight="46.0"
                            maxWidth="Infinity" />
                    <Button text="创建账号" onAction="#handleRegister"
                            styleClass="secondary-button" prefHeight="46.0"
                            maxWidth="Infinity" />
                </VBox>

                <Label fx:id="hintLabel" wrapText="true"
                       alignment="CENTER" />
            </VBox>
        </HBox>
    </center>
</BorderPane>