<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.AdminUserController">

	<top>
		<VBox spacing="16.0">
			<padding>
				<Insets bottom="24.0" />
			</padding>
			<HBox alignment="CENTER_LEFT" spacing="20.0">
				<Button text="← 控制台" onAction="#handleBack"
					styleClass="secondary-button" />
				<VBox>
					<Label text="用户管理" styleClass="page-title" />
					<Label fx:id="currentUserLabel" styleClass="muted-text" />
				</VBox>
			</HBox>

			<HBox alignment="BOTTOM_LEFT" spacing="12.0"
				styleClass="toolbar-panel">
				<VBox spacing="6.0" HBox.hgrow="ALWAYS">
					<Label text="搜索用户" styleClass="field-label" />
					<TextField fx:id="keywordField" promptText="按用户名搜索..."
						prefWidth="300.0" />
				</VBox>
				<Button text="搜索" onAction="#handleSearch"
					styleClass="primary-button" />
				<Button text="重置" onAction="#handleReset"
					styleClass="secondary-button" />

				<Region HBox.hgrow="ALWAYS" />

				<Button text="封禁用户" onAction="#handleBan"
					styleClass="danger-button" />
				<Button text="解封用户" onAction="#handleUnban"
					styleClass="secondary-button" />
			</HBox>
			<Label fx:id="summaryLabel" styleClass="status-text" />
		</VBox>
	</top>

	<center>
		<VBox spacing="16.0" styleClass="plain-panel">
			<Label text="所有用户" styleClass="section-label" />
			<TableView fx:id="userTable" VBox.vgrow="ALWAYS">
				<columns>
					<TableColumn fx:id="usernameColumn" text="用户名"
						prefWidth="180.0" />
					<TableColumn fx:id="phoneColumn" text="联系方式"
						prefWidth="180.0" />
					<TableColumn fx:id="roleColumn" text="角色"
						prefWidth="120.0" />
					<TableColumn fx:id="statusColumn" text="状态"
						prefWidth="120.0" />
					<TableColumn fx:id="goodsCountColumn" text="上架商品数"
						prefWidth="140.0" />
					<TableColumn fx:id="soldCountColumn" text="售出商品数"
						prefWidth="140.0" />
				</columns>
			</TableView>
		</VBox>
	</center>
</BorderPane>
