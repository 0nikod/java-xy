<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane styleClass="page-shell"
	xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="com.campus.secondhand.controller.UserCenterController">

	<top>
		<VBox spacing="20.0">
			<padding>
				<Insets bottom="24.0" />
			</padding>
			<HBox alignment="CENTER_LEFT" spacing="20.0">
				<VBox>
					<Label text="个人中心" styleClass="page-title" />
					<Label fx:id="currentUserLabel" styleClass="muted-text" />
				</VBox>
				<Region HBox.hgrow="ALWAYS" />
				<Button text="刷新数据" onAction="#handleRefresh"
					styleClass="secondary-button" />
			</HBox>

			<HBox styleClass="hero-panel" alignment="CENTER_LEFT">
				<padding>
					<Insets top="20.0" right="24.0" bottom="20.0" left="24.0" />
				</padding>
				<Label fx:id="summaryLabel" styleClass="section-label"
					wrapText="true" />
			</HBox>
		</VBox>
	</top>

	<center>
		<VBox spacing="16.0" styleClass="plain-panel">
			<TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
				styleClass="tab-pane">
				<tabs>
					<Tab text="我发布的">
						<VBox spacing="12.0">
							<padding>
								<Insets top="16.0" />
							</padding>
							<HBox alignment="CENTER_RIGHT">
								<Button text="下架商品" onAction="#handleOffShelf"
									styleClass="danger-button" />
							</HBox>
							<TableView fx:id="publishedGoodsTable"
								VBox.vgrow="ALWAYS">
								<columns>
									<TableColumn fx:id="publishedTitleColumn"
										text="商品名称" prefWidth="260.0" />
									<TableColumn fx:id="publishedCategoryColumn"
										text="类别" prefWidth="130.0" />
									<TableColumn fx:id="publishedPriceColumn" text="价格"
										prefWidth="110.0" />
									<TableColumn fx:id="publishedStatusColumn"
										text="状态" prefWidth="130.0" />
								</columns>
							</TableView>
						</VBox>
					</Tab>
					<Tab text="我买到的">
						<VBox spacing="12.0">
							<padding>
								<Insets top="16.0" />
							</padding>
							<HBox alignment="CENTER_RIGHT">
								<Button text="撰写评价" onAction="#handleCreateReview"
									styleClass="primary-button" />
							</HBox>
							<TableView fx:id="purchasedOrdersTable"
								VBox.vgrow="ALWAYS">
								<columns>
									<TableColumn fx:id="purchasedOrderNoColumn"
										text="订单号" prefWidth="240.0" />
									<TableColumn fx:id="purchasedGoodsColumn"
										text="商品名称" prefWidth="220.0" />
									<TableColumn fx:id="purchasedPriceColumn" text="价格"
										prefWidth="100.0" />
									<TableColumn fx:id="purchasedSellerColumn"
										text="卖家" prefWidth="140.0" />
								</columns>
							</TableView>
						</VBox>
					</Tab>
					<Tab text="我卖出的">
						<VBox spacing="12.0">
							<padding>
								<Insets top="16.0" />
							</padding>
							<TableView fx:id="soldOrdersTable" VBox.vgrow="ALWAYS">
								<columns>
									<TableColumn fx:id="soldOrderNoColumn" text="订单号"
										prefWidth="240.0" />
									<TableColumn fx:id="soldGoodsColumn" text="商品名称"
										prefWidth="220.0" />
									<TableColumn fx:id="soldPriceColumn" text="价格"
										prefWidth="100.0" />
									<TableColumn fx:id="soldBuyerColumn" text="买家"
										prefWidth="140.0" />
								</columns>
							</TableView>
						</VBox>
					</Tab>
					<Tab text="我发表的评价">
						<VBox spacing="12.0">
							<padding>
								<Insets top="16.0" />
							</padding>
							<TableView fx:id="publishedReviewsTable"
								VBox.vgrow="ALWAYS">
								<columns>
									<TableColumn fx:id="publishedReviewGoodsColumn"
										text="商品" prefWidth="200.0" />
									<TableColumn fx:id="publishedReviewRatingColumn"
										text="评分" prefWidth="100.0" />
									<TableColumn fx:id="publishedReviewContentColumn"
										text="内容" prefWidth="400.0" />
								</columns>
							</TableView>
						</VBox>
					</Tab>
					<Tab text="我收到的评价">
						<VBox spacing="12.0">
							<padding>
								<Insets top="16.0" />
							</padding>
							<TableView fx:id="receivedReviewsTable"
								VBox.vgrow="ALWAYS">
								<columns>
									<TableColumn fx:id="receivedReviewGoodsColumn"
										text="商品" prefWidth="200.0" />
									<TableColumn fx:id="receivedReviewRatingColumn"
										text="评分" prefWidth="100.0" />
									<TableColumn fx:id="receivedReviewContentColumn"
										text="内容" prefWidth="400.0" />
								</columns>
							</TableView>
						</VBox>
					</Tab>
				</tabs>
			</TabPane>
		</VBox>
	</center>
</BorderPane>
